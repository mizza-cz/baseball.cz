<div class="postsSlider">
  <div class="container">
    <ul class="postsSlider__inner">
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        <a href="#" class="post">
          <div class="tag">Reprezentace</div>
          <img
            loading="lazy"
            srcset="
              https://picsum.photos/672/672 672w,
              https://picsum.photos/336/336 336w
            "
            sizes="
                  (min-width: 336px) 336px,
                  calc(100vw - 2rem)
                "
            width="336"
            height="336"
            class="object-fit-cover"
            alt=""
          />
          <div class="post__content">
            <h3 class="h4 text-light mb-2">
              KPMG novým hlavním partnerem českého baseballu pro sezóny 2025 a
              2026
            </h3>
            <div class="text-tertiary text-md">24. 1. 2024</div>
          </div>
        </a>
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
      <li class="postsSlider__item">
        {% include "@components/post/post.twig" %}
      </li>
    </ul>
    <div class="postsSlider__nav">
      <a href="#" class="btn btn-primary">Zobrazit všechny články </a>
      <div class="postsSlider__btns">
        <button class="postsSlider__btn postsSlider__btnprev">
          {% include "@images/arrow-btn.svg" %}
        </button>

        <button class="postsSlider__btn postsSlider__btnnext">
          {% include "@images/arrow-btn.svg" %}
        </button>
      </div>
    </div>
  </div>
</div>
